local function CreateWing(side)
    local parts = {}

    for i = 1,6 do
        local p = Instance.new("Part")
        p.Anchored = false
        p.CanCollide = false
        p.Material = Enum.Material.Neon
        p.Color = Color3.fromRGB(170,0,255)
        p.Size = Vector3.new(0.35,0.35,4 + i)
        p.Name = "WingPart"

        local mesh = Instance.new("SpecialMesh", p)
        mesh.MeshType = Enum.MeshType.Sphere
        mesh.Scale = Vector3.new(0.3,0.3,1)

        local att0 = Instance.new("Attachment", p)
        local att1 = Instance.new("Attachment", p)

        att0.Position = Vector3.new(0,0,-p.Size.Z/2)
        att1.Position = Vector3.new(0,0,p.Size.Z/2)

        local trail = Instance.new("Trail")
        trail.Attachment0 = att0
        trail.Attachment1 = att1
        trail.Lifetime = 0.2
        trail.MinLength = 0
        trail.FaceCamera = true
        trail.Color = ColorSequence.new(Color3.fromRGB(200,0,255))
        trail.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0,0.1),
            NumberSequenceKeypoint.new(1,1)
        })
        trail.WidthScale = NumberSequence.new({
            NumberSequenceKeypoint.new(0,1.2),
            NumberSequenceKeypoint.new(1,0)
        })
        trail.Parent = p

        table.insert(parts,p)
    end

    return parts
end

