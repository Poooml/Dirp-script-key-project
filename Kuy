-- Fly objects
local bv, bg = nil, nil

local function CleanupFly()
    if bv then bv:Destroy(); bv = nil end
    if bg then bg:Destroy(); bg = nil end
end

local function StartFly(char, speed)
    CleanupFly()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    
    hum.PlatformStand = true
    
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Velocity = Vector3.zero
    bv.Parent = hrp
    
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 9e4
    bg.CFrame = hrp.CFrame
    bg.Parent = hrp
    
    local conn
    conn = RS.RenderStepped:Connect(function()
        if not CharacterConfig.FlyEnabled or not bv or not bg or not hrp.Parent then
            conn:Disconnect()
            CleanupFly()
            if hum and hum.Parent then hum.PlatformStand = false end
            return
        end
        
        bg.CFrame = camera.CFrame
        
        local move = hum.MoveDirection
        local vel = Vector3.zero
        
        if move.Magnitude > 0 then
            vel = camera.CFrame.LookVector * speed
        end
        
        bv.Velocity = vel
    end)
end

local function StopFly(char)
    CharacterConfig.FlyEnabled = false
    CleanupFly()
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
end
local AirPart = Instance.new("Part")
AirPart.Name = "NONNOIAirPlate"; AirPart.Size = Vector3.new(6, 0.5, 6); AirPart.Anchored = true; AirPart.Transparency = 1; AirPart.RootPriority = 1

local function IsTouchDamagePart(part)
    if part:IsA("TouchTransmitter") then return true end
    local name, pName = string.lower(part.Name), (part.Parent and string.lower(part.Parent.Name) or "")
    for _, word in ipairs({"kill", "lava", "hurt", "danger", "damage", "acid"}) do
        if string.find(name, word) or string.find(pName, word) then return true end
    end
    return false
end

local function SafeTeleport(root)
    if lastSafeCFrame and not tpCooldown then
        tpCooldown = true
        root.CFrame = lastSafeCFrame
        root.AssemblyLinearVelocity = Vector3.zero
        task.delay(0.25, function() tpCooldown = false end)
        return true
    end
end

local function PredictAndEvade(root, hum)
    if not CharacterConfig.DamageEvade or tpCooldown then return end
    local moveDir, vel = hum.MoveDirection, root.AssemblyLinearVelocity
    local castDir = (moveDir.Magnitude > 0 and moveDir or (vel.Magnitude > 1 and vel.Unit or nil))
    
    if castDir then
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = {localPlayer.Character, AirPart}
        for _, offset in ipairs({Vector3.zero, Vector3.new(1.5, -2, 0), Vector3.new(-1.5, -2, 0), Vector3.new(0, -2, 1.5), Vector3.new(0, -2, -1.5)}) do
            local res = workspace:Raycast(root.Position + offset, castDir * 8, params)
            if res and res.Instance and IsTouchDamagePart(res.Instance) then
                SafeTeleport(root)
                return
            end
        end
    end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Exclude
    params.FilterDescendantsInstances = {localPlayer.Character, AirPart}
    
    for angle = 0, 360, 45 do
        local rad = math.rad(angle)
        local dir = Vector3.new(math.cos(rad), 0, math.sin(rad))
        local res = workspace:Raycast(root.Position, dir * 5, params)
        if res and res.Instance and IsTouchDamagePart(res.Instance) then
            SafeTeleport(root)
            return
        end
    end
    
    local downRes = workspace:Raycast(root.Position, Vector3.new(0, -5, 0), params)
    if downRes and downRes.Instance and IsTouchDamagePart(downRes.Instance) then
        SafeTeleport(root)
        return
    end
    
    local parts = workspace:GetPartsInPart(AirPart)
    for _, part in iparts(parts) do
        if IsTouchDamagePart(part) then SafeTeleport(root) return end
    end
    
    if hum.FloorMaterial ~= Enum.Material.Air and vel.Magnitude < CharacterConfig.WalkSpeed + 5 then
        lastSafeCFrame = root.CFrame
    end
end
