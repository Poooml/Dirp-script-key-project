players.PlayerRemoving:Connect(CleanESP)
local function ApplyCharacterBypasses(char)
    local hum = char:WaitForChild("Humanoid", 5)
    local root = char:WaitForChild("HumanoidRootPart", 5)
    if not hum or not root then return end

    hum.HealthChanged:Connect(function()
        if CharacterConfig.DamageEvade and lastSafeCFrame and not tpCooldown then
            SafeTeleport(root)
        end
    end)

    hum:GetPropertyChangedSignal("WalkSpeed"):Connect(function()
        if hum.WalkSpeed ~= CharacterConfig.WalkSpeed then hum.WalkSpeed = CharacterConfig.WalkSpeed end
    end)
    hum:GetPropertyChangedSignal("JumpPower"):Connect(function()
        if hum.JumpPower ~= CharacterConfig.JumpPower then hum.JumpPower = CharacterConfig.JumpPower end
    end)
    
    hum.UseJumpPower = true
    hum.WalkSpeed = CharacterConfig.WalkSpeed
    hum.JumpPower = CharacterConfig.JumpPower
    
    if CharacterConfig.FlyEnabled then
        task.wait(0.5)
        StartFly(char, CharacterConfig.FlySpeed)
    end
end

